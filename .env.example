# --- Core ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/d_global?schema=public"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- WhatsApp (E.164 without +) ---
# Ghana country code 233, e.g. 233241234567
NEXT_PUBLIC_WHATSAPP_NUMBER="233241234567"

# --- Paystack ---
# Mode: "link" (use hardcoded Paystack Payment Links) or "api" (full initialize + webhook flow)
PAYSTACK_MODE="link"
PAYSTACK_SECRET_KEY=""
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""

# --- Ticket QR signing ---
# Any long random string; used as HMAC key for QR token integrity.
QR_SECRET="change-me-to-a-long-random-string"

# --- Optional ---
GOOGLE_MAPS_API_KEY=""
