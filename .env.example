# --- Core ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/d_global?schema=public"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- WhatsApp (E.164 without +) ---
# Ghana country code 233, e.g. 233241234567
NEXT_PUBLIC_WHATSAPP_NUMBER="233241234567"

# --- Paystack ---
# Mode: "link" (hosted Paystack Payment Links) or "api" (initialize + webhook).
PAYSTACK_MODE="link"
PAYSTACK_SECRET_KEY=""

# --- Ticket QR signing ---
# Any long random string; HMAC key for QR token integrity.
QR_SECRET="change-me-to-a-long-random-string"

# --- Auth (NextAuth v5) ---
# Required in production. Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Comma-separated email allowlist for /admin access.
ADMIN_EMAILS="founder@d-global.example,ops@d-global.example"

# --- Email (Resend) ---
# Used for magic-link sign-in and order confirmations. Without it, the
# auth email provider falls back to logging the magic link to the server
# console (dev convenience) and order emails are skipped.
RESEND_API_KEY=""
EMAIL_FROM="D-Global <noreply@d-global.example>"

# --- Analytics (Plausible) ---
# Leave domain blank to disable the script entirely. Self-hosted users
# can override the script URL.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL="https://plausible.io/js/script.js"

# --- Error tracking (Sentry) ---
# DSNs are public; they're tied to a single project and rate-limited.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Optional environment tag (defaults to NODE_ENV). Useful for staging vs prod.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=""
SENTRY_ENVIRONMENT=""
# Build-time only — used for source map upload, not the runtime SDK.
# SENTRY_RELEASE is auto-detected from VERCEL_GIT_COMMIT_SHA / GITHUB_SHA;
# only set explicitly if you manage releases by semver tag.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
SENTRY_RELEASE=""

# --- Web push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:ops@d-global.example"

# --- CSP rollout ---
# Set to "1" to ship CSP in Report-Only mode (browsers report violations
# to /api/csp-report but don't block anything). Use this when introducing
# a tightening change so you can watch Sentry for breakage before flipping
# back to enforcing. Production-only; dev never sets a CSP at all.
CSP_REPORT_ONLY=""
