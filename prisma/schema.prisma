// D-Global Prisma schema, digital nightlife ecosystem.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  ADMIN
  STAFF
  ARTIST
}

enum TicketTier {
  EARLY_BIRD
  REGULAR
  VIP
  TABLE
}

enum PackageTier {
  SILVER
  GOLD
  PLATINUM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLIST
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  SOLD_OUT
  CANCELLED
}

enum ReleaseKind {
  SINGLE
  EP
  ALBUM
  MIX
  VIDEO
}

enum GalleryCategory {
  EVENTS
  BACKSTAGE
  ARTISTS
  VENUE
  CAMPAIGN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  name          String?
  role          Role      @default(GUEST)
  bookings      Booking[]
  orders        Order[]
  // NextAuth (PrismaAdapter) relations. The adapter writes into these on
  // sign-in/link account flows, we never touch them directly.
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([phone])
}

// --- NextAuth (Auth.js v5) PrismaAdapter tables ---
// Schemas are dictated by @auth/prisma-adapter, don't drift from them.
// https://authjs.dev/getting-started/adapters/prisma#schema

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Web push subscription. One row per (endpoint), endpoints are unique
// per (browser, device, user). userId is optional because guests can
// subscribe before signing in (e.g. for an event drop reminder).
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Event {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  subtitle      String?
  description   String
  startsAt      DateTime
  endsAt        DateTime?
  doorsAt       DateTime?
  venueName     String
  venueCity     String         @default("Accra")
  venueAddress  String?
  venueMapUrl   String?
  latitude      Float?
  longitude     Float?
  heroImage     String
  genre         String[]       @default([])
  status        EventStatus       @default(DRAFT)
  featured      Boolean           @default(false)
  ticketTypes   TicketType[]
  lineup        LineupSlot[]
  bookings      Booking[]
  orders        Order[]
  galleryImages GalleryImage[]
  scanTokens    EventScanToken[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([startsAt])
  @@index([status, featured, startsAt])
  @@index([venueCity])
}

model TicketType {
  id              String      @id @default(cuid())
  eventId         String
  event           Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tier            TicketTier
  name            String
  description     String?
  priceMinor      Int
  currency        String      @default("GHS")
  quota           Int
  sold            Int         @default(0)
  salesStart      DateTime?
  salesEnd        DateTime?
  paymentLinkUrl  String?
  orderItems      OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // One row per (event, tier). The admin CRUD has a pre-check, but
  // without a DB-level unique constraint two concurrent submissions
  // can both pass the check and insert duplicates, that would confuse
  // the public checkout (cheapest-tier lookup is ambiguous) and make
  // the `sold` counter unreliable. The unique makes the P2002 catch in
  // upsertTicketType actually reachable and closes the race.
  @@unique([eventId, tier])
}

model LineupSlot {
  id          String    @id @default(cuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  artistId    String?
  artist      Artist?   @relation(fields: [artistId], references: [id])
  displayName String
  role        String?
  image       String?
  slotStart   DateTime?
  order       Int       @default(0)

  @@index([eventId, order])
  @@index([artistId])
}

model Package {
  id          String        @id @default(cuid())
  tier        PackageTier   @unique
  name        String
  tagline     String?
  description String?
  priceMinor  Int
  currency    String        @default("GHS")
  perks       String[]      @default([])
  maxGuests   Int
  bottlesIncl Int           @default(0)
  heroImage   String?
  active      Boolean       @default(true)
  soldOut     Boolean       @default(false)
  bookings    Booking[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Booking {
  id           String        @id @default(cuid())
  code         String        @unique @default(cuid())
  userId       String?
  user         User?         @relation(fields: [userId], references: [id])
  eventId      String?
  event        Event?        @relation(fields: [eventId], references: [id])
  packageId    String
  package      Package       @relation(fields: [packageId], references: [id])
  guestName    String
  guestPhone   String
  guestEmail   String?
  partySize    Int           @default(2)
  requestedAt  DateTime      @default(now())
  notes        String?
  status       BookingStatus @default(PENDING)
  whatsappSent Boolean       @default(false)
  updatedAt    DateTime      @updatedAt

  @@index([eventId, status])
  @@index([guestPhone])
}

model Order {
  id              String      @id @default(cuid())
  reference       String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  eventId         String
  event           Event       @relation(fields: [eventId], references: [id])
  buyerEmail      String
  buyerName       String
  buyerPhone      String?
  totalMinor      Int
  currency        String      @default("GHS")
  status          OrderStatus @default(PENDING)
  paystackPayload Json?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  paidAt          DateTime?

  @@index([buyerEmail])
  @@index([status, createdAt])
}

model OrderItem {
  id             String     @id @default(cuid())
  orderId        String
  order          Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketTypeId   String
  ticketType     TicketType @relation(fields: [ticketTypeId], references: [id])
  quantity       Int
  unitPriceMinor Int
  qrToken        String?    @unique
  scannedAt      DateTime?

  @@index([orderId])
}

// Tokenised scanner link for an event. Admins hand the URL to the
// gate crew; the scanner page loads on their phone and validates QR
// codes against the event. Each token is its own unguessable cuid so
// compromise is revocable per-gate without rotating secrets globally.
// onDelete: Cascade because tokens are meaningless once the event is
// gone (admin deleteEvent already refuses while Orders exist, so this
// cascade only fires on empty-event cleanup).
model EventScanToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  label     String?
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  revokedAt DateTime?

  @@index([eventId])
}

model Artist {
  id              String           @id @default(cuid())
  slug            String           @unique
  stageName       String
  bio             String?
  avatar          String?
  heroImage       String?
  spotifyId       String?
  audiomackId     String?
  instagram       String?
  twitter         String?
  featured        Boolean          @default(false)
  releases        Release[]
  lineupSlots     LineupSlot[]
  artistBookings  ArtistBooking[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([featured])
}

// Label-side artist-booking requests. Distinct from `Booking` (which is
// the VIP-table/package flow). Fields are the minimum a label needs to
// quote: who wants the artist, when, where, for what, and how to reach
// them. Budget is optional because serious inbound often wants to chat
// before quoting a number.
enum ArtistBookingStatus {
  PENDING
  REVIEWING
  CONFIRMED
  DECLINED
  CANCELLED
}

model ArtistBooking {
  id              String              @id @default(cuid())
  code            String              @unique @default(cuid())
  artistId        String
  artist          Artist              @relation(fields: [artistId], references: [id])
  requesterName   String
  requesterEmail  String
  requesterPhone  String
  company         String?
  eventDate       DateTime
  venueName       String
  city            String
  country         String              @default("Ghana")
  budgetMinor     Int?
  currency        String              @default("GHS")
  notes           String?
  status          ArtistBookingStatus @default(PENDING)
  requestedAt     DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([artistId, status])
  @@index([status, requestedAt])
}

model Release {
  id           String      @id @default(cuid())
  slug         String      @unique
  artistId     String
  artist       Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title        String
  kind         ReleaseKind @default(SINGLE)
  coverImage   String
  releasedAt   DateTime
  spotifyUrl   String?
  audiomackUrl String?
  youtubeUrl   String?
  tracks       Track[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([artistId, releasedAt])
}

model Track {
  id          String  @id @default(cuid())
  releaseId   String
  release     Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  title       String
  durationSec Int?
  spotifyId   String?
  order       Int     @default(0)

  @@index([releaseId, order])
}

model GalleryImage {
  id        String          @id @default(cuid())
  url       String
  blurData  String?
  caption   String?
  category  GalleryCategory @default(EVENTS)
  eventId   String?
  event     Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  featured  Boolean         @default(false)
  order     Int             @default(0)
  createdAt DateTime        @default(now())

  @@index([category, order])
  @@index([eventId])
}
