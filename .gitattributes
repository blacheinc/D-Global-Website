# Normalize all text files to LF on commit.
* text=auto eol=lf

# Explicit text types.
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.prisma   text eol=lf
*.webmanifest text eol=lf

# Binary assets — never normalized, never diffed as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.avif  binary
*.mp4   binary
*.webm  binary
*.mov   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
